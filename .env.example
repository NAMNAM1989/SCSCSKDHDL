# Đồng bộ đa thiết bị (tùy chọn) — Supabase Realtime
# Tạo project tại https://supabase.com, chạy supabase/schema.sql, rồi điền:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Một “phòng” dữ liệu chung (cùng nhóm dùng chung một docId). Mặc định: default
# NEXT_PUBLIC_SYNC_DOC_ID=default

# --- Đăng nhập 2 nút (Admin / User), không nhập email trên màn hình ---
# Khi CẢ HAI mật khẩu dưới đây đều có giá trị, app hiện hai nút đăng nhập.
# Trong Supabase tạo đúng 2 user (xem docs/auth-rbac-setup.md):
#   admin@cutoffscsc.internal  + app_metadata.role = admin
#   viewer@cutoffscsc.internal + app_metadata.role = viewer
# (Tuỳ chọn) ghi đè email:
# NEXT_PUBLIC_CUTOFF_PRESET_ADMIN_EMAIL=
# NEXT_PUBLIC_CUTOFF_PRESET_VIEWER_EMAIL=
NEXT_PUBLIC_CUTOFF_PRESET_ADMIN_PASSWORD=
NEXT_PUBLIC_CUTOFF_PRESET_VIEWER_PASSWORD=
